# =============================================================================
# IslaGrid environment variables
# =============================================================================
# Copy this file to `.env.local` (Next.js) and `ingestion/.env` (Python),
# then fill in the values. See docs/SETUP.md for where each value comes from.

# -----------------------------------------------------------------------------
# Supabase (required) — https://supabase.com (free tier)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used by Python ingestion (same project, just different env-var names)
SUPABASE_URL=

# -----------------------------------------------------------------------------
# Upstash Redis (required in production) — https://upstash.com (free tier)
# Without this in production, the public API fails closed with HTTP 503.
# Optional in dev — the rate limiter passes through unbounded.
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Cloudflare R2 (required for ingestion) — https://developers.cloudflare.com/r2
# Free tier covers our raw-archive volume. Bucket can be any name; we default
# to islagrid-raw.
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=islagrid-raw
R2_ENDPOINT=

# -----------------------------------------------------------------------------
# NWS — public domain, no key required. Send a real contact email so NWS can
# reach you if you start hammering them.
# -----------------------------------------------------------------------------
NWS_USER_AGENT=islagrid-ai/0.1 (your-email@example.com)

# -----------------------------------------------------------------------------
# NREL PVWatts v8 (required for /solar) — free key at developer.nlr.gov
# Host defaults to the post-2026-05-29 hostname; override only if NREL runs
# a parallel migration period.
# -----------------------------------------------------------------------------
NREL_API_KEY=
NREL_API_HOST=developer.nlr.gov

# -----------------------------------------------------------------------------
# Nominatim geocoder (required for /solar) — free, OSM.
# Send a real contact email per Nominatim's usage policy.
# -----------------------------------------------------------------------------
GEOCODER_UA=islagrid-ai/0.1 (your-email@example.com)

# Optional: kill-switch if you want to disable geocoding entirely.
# NOMINATIM_DISABLED=true

# -----------------------------------------------------------------------------
# Public API security (Block 1 hardening)
# -----------------------------------------------------------------------------
# Pepper for HMAC-SHA-256 of API keys. Rotate to invalidate every key at once.
# Required in production; defaults to plain SHA-256 in dev with a warning.
API_KEY_PEPPER=

# Salt for hashing IPs stored on community_reports. Set this in production
# for actual anonymity guarantees (the default is a constant string).
REPORT_IP_SALT=

# Trust X-Forwarded-For only when you're behind a known proxy chain
# (Vercel, Cloudflare). Without this, clientIp() returns "unknown".
TRUST_PROXY=true

# Public site URL (used for the /api/reports POST origin allow-list).
NEXT_PUBLIC_SITE_URL=https://islagrid.example.com

# Comma-separated extra allowed origins for /api/reports POST.
# REPORTS_ALLOWED_ORIGINS=https://staging.islagrid.example.com

# -----------------------------------------------------------------------------
# LUMA scraping (optional overrides)
# -----------------------------------------------------------------------------
# LUMA's main site is at lumapr.com. If they ever stand up a separate operator
# host, point at it. Default is lumapr.com.
LUMA_OPERATOR_HOST=lumapr.com

# Override if LUMA migrates the ArcGIS FeatureServer behind miluma.lumapr.com.
# LUMA_OUTAGE_ARCGIS_URL=

# -----------------------------------------------------------------------------
# Social sources (Block 2)
# -----------------------------------------------------------------------------
# Comma-separated Bluesky search queries.
# BLUESKY_KEYWORDS=apagón puerto rico,LUMA energía,sin luz pr

# Mastodon instance to search; default mastodon.social.
# MASTODON_INSTANCE=mastodon.social
# MASTODON_KEYWORDS=apagón Puerto Rico,LUMA Energy

# -----------------------------------------------------------------------------
# Historical-data ingest (Block 6)
# -----------------------------------------------------------------------------
# DOE EAGLE-I archive URL — point at the current ORNL figshare release.
# See https://figshare.com/articles/dataset/24237376 for the latest.
EAGLE_I_DATA_URL=

# -----------------------------------------------------------------------------
# Trained outage-risk model (Block 7) — optional
# -----------------------------------------------------------------------------
# Path to a local .joblib bundle. If unset and no /tmp/outage_risk.joblib
# exists, the runtime uses the heuristic.
# OUTAGE_RISK_MODEL_PATH=/var/lib/islagrid/outage_risk-v1.joblib

# -----------------------------------------------------------------------------
# Notifications (Block 4 stub) — not yet wired
# -----------------------------------------------------------------------------
# Set these to enable Twilio-backed SMS digests once the integration ships.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
