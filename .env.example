# Supabase (https://supabase.com — free tier)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (https://upstash.com — free tier)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare R2 (https://developers.cloudflare.com/r2 — free tier)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=islagrid-raw
R2_ENDPOINT=

# NWS requires an identifying User-Agent
NWS_USER_AGENT=islagrid-ai/0.1 (iantdm11@gmail.com)

# NREL PVWatts v8 — used by /solar (Phase 11). Free key at developer.nlr.gov.
# Host defaults to the post-2026-05-29 hostname; set NREL_API_HOST if NREL
# rolls back or runs a parallel migration period.
NREL_API_KEY=
NREL_API_HOST=developer.nlr.gov

# Geocoder for /solar address lookups. Default is Nominatim (free, OSM).
GEOCODER_UA=islagrid-ai/0.1 (iantdm11@gmail.com)

# Optional: salt for hashing IPs in community_reports (Phase 8). Defaults to
# a constant string if unset — set this in production for actual anonymity.
REPORT_IP_SALT=
